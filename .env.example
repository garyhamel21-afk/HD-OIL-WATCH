# 한국은행 ECOS API 키 (환율, 무료 발급)
# https://ecos.bok.or.kr/ 회원가입 후 API 키 신청
BOK_API_KEY=YOUR_BOK_API_KEY_HERE

# 오피넷 API 키 (한국석유공사 오픈API 무료 발급)
# https://www.opinet.co.kr/user/custapi/custApiGruide.do
OPINET_API_KEY=YOUR_OPINET_API_KEY_HERE

# FRED API 키 (두바이유 DCOILDUBBI 조회용)
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=YOUR_FRED_API_KEY_HERE
